FROM node:20-slim
RUN corepack enable
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
WORKDIR /app
COPY . .
RUN pnpm install --no-frozen-lockfile
RUN pnpm --filter apatris-dashboard build
FROM node:20-slim
RUN npm install -g serve
WORKDIR /app
COPY --from=0 /app/artifacts/apatris-dashboard/dist ./dist
EXPOSE 3000
CMD ["serve", "-s", "dist", "-l", "3000"]
