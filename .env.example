# ============================================
# EURO EDU JOBS (EEJ) — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ── Server ─────────────────────────────────
PORT=8080
NODE_ENV=development
APP_URL=http://localhost:5173

# ── Database (PostgreSQL) ──────────────────
# Required — no Airtable dependency anymore
DATABASE_URL=postgresql://user:password@localhost:5432/eej

# ── Authentication ─────────────────────────
# Required — must be a random string (no fallback)
JWT_SECRET=your-random-jwt-secret-minimum-32-chars

# Admin credentials (for the primary admin account)
EEJ_ADMIN_EMAIL=anna.b@edu-jobs.eu
EEJ_ADMIN_PASSWORD=your-secure-admin-password

# ── AI — Anthropic Claude ──────────────────
# Used for document scanning, CV analysis, compliance copilot, regulatory analysis
ANTHROPIC_API_KEY=sk-ant-api-...

# ── AI — Perplexity (Regulatory Intelligence) ──
# Used for daily monitoring of Polish government regulatory changes
PERPLEXITY_API_KEY=pplx-...

# ── Email — Brevo SMTP (Primary) ──────────
# smtp-relay.brevo.com port 587
BREVO_SMTP_USER=your-brevo-login@example.com
BREVO_SMTP_PASS=your-brevo-smtp-password

# ── Email — Resend (Alternative) ──────────
# RESEND_API_KEY=re_...

# ── Email — Generic SMTP (Fallback) ───────
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=noreply@edu-jobs.eu

# ── Email Alerts ───────────────────────────
ALERT_EMAIL_TO=admin@edu-jobs.eu

# ── SMS / WhatsApp — Twilio ────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── File Storage — Cloudflare R2 ──────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=eej-documents

# ── Maps — Mapbox ─────────────────────────
# Used for GPS worker location maps and site geofences
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...

# ── Payments — Stripe ─────────────────────
# Subscription billing for agencies
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: pre-created price IDs for each plan
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PROFESSIONAL_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Cron Schedules ─────────────────────────
# Compliance alert check (default: 8am daily)
ALERT_CRON=0 8 * * *
# Regulatory intelligence scan (default: 7am daily)
REGULATORY_CRON=0 7 * * *

# ── Logging ────────────────────────────────
LOG_LEVEL=info
