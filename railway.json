{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api-server": {
      "build": {
        "buildCommand": "pnpm --filter @workspace/api-server build"
      },
      "deploy": {
        "startCommand": "cd artifacts/api-server && pnpm start"
      }
    },
    "apatris-dashboard": {
      "build": {
        "buildCommand": "pnpm --filter @workspace/apatris-dashboard build"
      },
      "deploy": {
        "startCommand": "cd artifacts/apatris-dashboard && npx serve -s dist -p $PORT"
      }
    }
  }
}
